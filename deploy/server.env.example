# Copy to ~/.config/mission-control/server.env on the server machine
# (Strix Halo). Loaded by deploy/mission-control.service via
# EnvironmentFile. Keep this out of git — it's gitignored.

PORT=3001

# Must match the api_key in every collector.toml that talks to this server.
MC_API_KEY=changeme

# Leave unset/false for now (single-user, LAN/tailnet-only). Set to true and
# fill in MC_PASSWORD_HASH to require login for the web UI.
MC_AUTH_ENABLED=false
