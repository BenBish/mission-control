# Copy to ~/.config/mission-control/server.env on the server machine
# (Strix Halo). Loaded by deploy/mission-control.service via
# EnvironmentFile. Keep this out of git — it's gitignored.

PORT=3001

# Must match the api_key in every collector.toml that talks to this server.
MC_API_KEY=changeme

# Leave unset/false for now (single-user, LAN/tailnet-only). Set to true and
# fill in MC_PASSWORD_HASH to require login for the web UI.
MC_AUTH_ENABLED=false

# Set to true only on the box actually running llama-swap/llama-server
# (Strix Halo) — the Hermes poller hits 127.0.0.1:8080/12345/12346/12347
# and shells out to `journalctl` for llama-toolbox-*/hermes-gateway-*
# units directly, none of which exist anywhere else. Leave unset/false on
# any other deployment.
MC_HERMES_POLLING_ENABLED=false

# Provider billing connectors (OpenRouter / Anthropic / OpenAI / xAI).
# These pull account-level usage/cost via provider Admin/usage APIs and store
# rows in provider_usage_daily — distinct from session-log agent costs.
# Leave keys unset to keep connectors in not_configured status.
# OPENROUTER_API_KEY=
# ANTHROPIC_ADMIN_KEY=   # sk-ant-admin01-… (not a standard Claude key)
# OPENAI_ADMIN_KEY=      # Organization Admin key (not a project inference key)
# XAI_API_KEY=
# Optional: custom JSON usage export for xAI (no public usage history API yet)
# MC_XAI_USAGE_ENDPOINT=
# Set true to poll providers on an interval (manual POST /api/providers/sync always works)
# MC_PROVIDER_SYNC_ENABLED=false
# MC_PROVIDER_SYNC_INTERVAL_MS=3600000
