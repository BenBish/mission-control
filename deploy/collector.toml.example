# Copy to ~/.config/mission-control/collector.toml on the desktop machine.

# Server's ingest endpoint. The server binds 127.0.0.1:3001 on the server
# machine and is exposed via `tailscale serve` (TLS termination + tailnet
# ACLs) at its full MagicDNS name — not the short hostname, and not http://.
# Check the exposed URL with `tailscale serve status` on the server machine.
server_url = "https://fedora.taile952db.ts.net:3001"

# Matches MC_API_KEY on the server (src/server/auth.ts) — grants the ingest
# routes bypass without needing a JWT session.
api_key = "changeme"

# Informational only for now — shown in source_instances.meta.
machine = "arch-desktop"
